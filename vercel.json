{
    "version": 2,
    "redirects": [
        {
            "source": "/",
            "destination": "/login",
            "permanent": false
        }
    ],
    "rewrites": [
        {
            "source": "/favicon.ico",
            "destination": "/public/favicon.svg"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/login",
            "destination": "/public/login.html"
        },
        {
            "source": "/register",
            "destination": "/public/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/public/$1"
        }
    ]
}