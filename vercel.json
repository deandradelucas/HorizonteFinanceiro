{
    "version": 2,
    "builds": [
        {
            "src": "index.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/(css|js|images|ico|json|txt|html)/(.+)",
            "dest": "/$1/$2",
            "headers": {
                "cache-control": "s-maxage=31536000, immutable"
            }
        },
        {
            "src": "/(.*)",
            "dest": "index.js"
        }
    ]
}