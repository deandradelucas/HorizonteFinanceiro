{
    "version": 2,
    "functions": {
        "api/**/*.js": {
            "includeFiles": "{db.js,node_modules/iconv-lite/lib/**,node_modules/iconv-lite/encodings/**,node_modules/body-parser/lib/**}"
        }
    },
    "redirects": [
        {
            "source": "/",
            "destination": "/login",
            "permanent": false
        }
    ],
    "rewrites": [
        {
            "source": "/favicon.ico",
            "destination": "/public/favicon.svg"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/login",
            "destination": "/public/login.html"
        },
        {
            "source": "/register",
            "destination": "/public/index.html"
        },
        {
            "source": "/(.*)",
            "destination": "/public/$1"
        }
    ]
}